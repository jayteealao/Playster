# Added by wf-meta build-pipeline — plan v1, 2026-06-20
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{kt,kts}]
indent_size = 4
# @Composable functions follow PascalCase by Compose convention, not ktlint's camelCase rule.
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab
