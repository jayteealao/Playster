# Local secret overrides for the Functions emulator (dotenv format).
# Copy to .secret.local (gitignored via *.local) and adjust as needed.
#
# The emulator binds secret values at suite START — restart the suite after
# creating or editing .secret.local (no hot reload; probe-proven 2026-07-19).
#
# For the manual-summary Maestro flow, a trivial local mock satisfies the
# dispatch (the flow only asserts the in-progress state):
#   node -e "require('http').createServer((q,s)=>{s.writeHead(200,{'Content-Type':'application/json'});s.end(JSON.stringify({id:'mock-job-1'}))}).listen(18080)"
SUMMARIZER_URL=http://127.0.0.1:18080
SUMMARIZER_API_KEY=local-mock-key
