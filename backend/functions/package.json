{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .ts,.js src/",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "pnpm run build && firebase emulators:start --only functions",
    "shell": "pnpm run build && firebase functions:shell",
    "start": "pnpm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/{autoEnqueue,callable,dispatch,dispatcher,quota,reconcile,resummarize,retry,rules,rules-summaries,rules-transcripts,sweeper,transcript-automation,transcript-fetch,webhook}.test.ts'",
    "test:rules": "vitest run tests/rules.test.ts"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/storage": "7.21.0",
    "firebase-admin": "^14.1.0",
    "firebase-functions": "7.2.5",
    "googleapis": "^148.0.0",
    "youtubei.js": "17.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "firebase": "^12.0.0",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "private": true
}
