# =============================================================================
# Summarize API — Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
# =============================================================================

# ---------------------
# Required
# ---------------------

# Shared token for authenticating with the summarize daemon.
# Must be at least 16 characters.
SUMMARIZE_TOKEN=change-me-to-a-secure-token

# Comma-separated list of API keys that clients use to authenticate with the API.
# Example: API_KEYS=key1,key2,key3
API_KEYS=

# ---------------------
# LLM Provider Keys
# ---------------------

# At least one LLM key is needed for summarization to work.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------
# API Server Settings
# ---------------------

# Host port to expose the API on (maps to container port 3000).
API_PORT=3000

# Maximum file upload size in bytes (default: 100MB).
# MAX_UPLOAD_SIZE=104857600

# Maximum number of concurrent summarization jobs (default: 5).
# MAX_CONCURRENT_JOBS=5

# Job timeout in milliseconds (default: 300000 = 5 minutes).
# JOB_TIMEOUT_MS=300000

# Rate limit: max requests per window (default: 30).
# RATE_LIMIT_MAX=30
