# =============================================================================
# Summarize — Environment Configuration
# =============================================================================
# This file is read by both systemd services:
#   - summarize-daemon (the upstream summarize CLI daemon)
#   - summarize-api (the REST API server)
#
# Location: /etc/summarize/summarize.env
# After editing, restart services:
#   systemctl restart summarize-daemon summarize-api
# =============================================================================

# ---------------------
# Required
# ---------------------

# Shared token for authenticating with the summarize daemon.
# Must match between the API and daemon. Use a long random string.
# Generate one with: openssl rand -hex 32
SUMMARIZE_TOKEN=change-me-to-a-secure-token

# Comma-separated list of API keys that clients use to authenticate.
# These go in the Authorization header: "Bearer <key>"
# Example: API_KEYS=sk-abc123,sk-def456
API_KEYS=

# ---------------------
# LLM Provider Keys
# ---------------------
# At least one LLM key is needed for summarization to work.

OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=

# ---------------------
# Daemon Settings
# ---------------------

# Port the daemon listens on (default: 8787).
# Both the daemon and API must agree on this.
# DAEMON_PORT=8787

# ---------------------
# API Server Settings
# ---------------------
# These are set in the systemd unit by default, but can be overridden here.

# Port the API server listens on (default: 3000).
# PORT=3000

# Bind address (default: 0.0.0.0).
# HOST=0.0.0.0

# URL of the summarize daemon (default: http://127.0.0.1:8787).
# DAEMON_URL=http://127.0.0.1:8787

# Path to the SQLite database (default: /opt/summarize/api/data/jobs.db).
# DB_PATH=/opt/summarize/api/data/jobs.db

# Maximum file upload size in bytes (default: 100 MB).
# MAX_UPLOAD_SIZE=104857600

# Maximum number of concurrent summarization jobs (default: 5).
# MAX_CONCURRENT_JOBS=5

# Job timeout in milliseconds (default: 300000 = 5 minutes).
# JOB_TIMEOUT_MS=300000

# Rate limit: max requests per window (default: 30).
# RATE_LIMIT_MAX=30

# Rate limit window duration (default: "1 minute").
# RATE_LIMIT_WINDOW=1 minute
